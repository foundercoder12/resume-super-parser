# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://resume:resume@postgres:5432/resume_parser

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local           # local | s3
STORAGE_LOCAL_PATH=/data/uploads
# STORAGE_S3_BUCKET=my-bucket
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# ── External APIs ─────────────────────────────────────────────────────────────
MISTRAL_API_KEY=
GEMINI_API_KEY=

# ── Pipeline tuning ───────────────────────────────────────────────────────────
OCR_QUALITY_THRESHOLD=0.6       # Score below this triggers Mistral OCR
MAX_FILE_SIZE_MB=20
DEFAULT_RETAIN_DAYS=30

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development             # development | production
LOG_LEVEL=INFO
